---
// Comentario en espanol mexicano: este componente o pagina arma una seccion del portafolio.
// Archivo: WorkTimelineCard.astro
interface Props {
  title: string;
  company: string;
  years: string;
  description: string;
}

const { title, company, years, description } = Astro.props;
---

<div class="relative pl-8 sm:pl-32 py-6 group">
  <div class="flex flex-col sm:flex-row items-start mb-1">
    <p class="text-sm text-neutral-subtle dark:text-dark-subtle-text uppercase tracking-widest mb-1 sm:mb-0 sm:mr-4 min-w-[80px]">{years}</p>
    <div>
      <h3 class="text-xl font-semibold text-neutral-text dark:text-dark-text">{title}</h3>
      <p class="text-neutral-text dark:text-dark-text">{company}</p>
    </div>
  </div>
  <p class="text-neutral-subtle dark:text-dark-subtle-text mt-2">{description}</p>
  
  <!-- Timeline dot and line -->
  <div class="absolute left-0 top-0 h-full w-px bg-rich-blue/20 dark:bg-pale-gray/10 group-last:h-1/2"></div>
  <div class="absolute left-[-6px] top-6 w-3 h-3 rounded-full bg-accent-blue z-10"></div>
</div>