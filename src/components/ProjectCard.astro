---
// Comentario en espanol mexicano: este componente o pagina arma una seccion del portafolio.
// Archivo: ProjectCard.astro
interface Props {
  title: string;
  description: string;
  image: string;
  tags: string[];
  link: string;
  github?: string;
}

const { title, description, image, tags, link, github } = Astro.props;
---

<div class="group relative bg-[#F0EEE9] border-4 border-[#191265] overflow-hidden transition-all duration-500 hover:shadow-[12px_12px_0px_0px_#191265]">
  <!-- Imagen del Proyecto -->
  <div class="relative h-64 overflow-hidden border-b-4 border-[#191265]">
    <img 
      src={image} 
      alt={title} 
      class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 scale-105 group-hover:scale-110"
    />
    <div class="absolute inset-0 bg-[#191265]/20 group-hover:bg-transparent transition-colors duration-500"></div>
    
    <!-- Badge de Tags -->
    <div class="absolute top-4 left-4 flex flex-wrap gap-2">
      {tags.map(tag => (
        <span class="bg-[#191265] text-[#F0EEE9] text-[10px] font-black uppercase px-2 py-1 tracking-widest">
          {tag}
        </span>
      ))}
    </div>
  </div>

  <!-- Contenido -->
  <div class="p-8 space-y-4">
    <div class="flex justify-between items-start">
      <h3 class="text-3xl font-black text-[#191265] uppercase tracking-tighter leading-none italic">
        {title}
      </h3>
      <div class="flex items-center gap-3">
        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`GitHub repository for ${title}`}
            class="flex h-10 w-10 items-center justify-center border-2 border-[#191265] bg-[#F0EEE9] text-[#191265] transition-all duration-300 hover:-translate-y-0.5 hover:bg-[#191265] hover:text-[#F0EEE9]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.48 2 2 6.58 2 12.24C2 16.77 4.87 20.61 8.84 21.97C9.34 22.07 9.52 21.75 9.52 21.48C9.52 21.24 9.51 20.44 9.5 19.59C6.73 20.21 6.14 18.23 6.14 18.23C5.68 17.03 5.03 16.71 5.03 16.71C4.12 16.07 5.1 16.08 5.1 16.08C6.11 16.16 6.64 17.15 6.64 17.15C7.54 18.73 8.99 18.27 9.56 17.99C9.65 17.31 9.91 16.86 10.2 16.61C7.99 16.35 5.67 15.47 5.67 11.52C5.67 10.39 6.07 9.47 6.73 8.75C6.62 8.49 6.28 7.41 6.83 5.95C6.83 5.95 7.67 5.67 9.5 6.95C10.29 6.72 11.15 6.61 12 6.61C12.85 6.61 13.71 6.72 14.5 6.95C16.33 5.67 17.17 5.95 17.17 5.95C17.72 7.41 17.38 8.49 17.27 8.75C17.93 9.47 18.33 10.39 18.33 11.52C18.33 15.48 16 16.35 13.79 16.61C14.16 16.94 14.5 17.57 14.5 18.53C14.5 19.9 14.49 21.09 14.49 21.48C14.49 21.75 14.67 22.08 15.18 21.97C19.14 20.61 22 16.77 22 12.24C22 6.58 17.52 2 12 2Z" />
            </svg>
          </a>
        )}
        <a href={link} class="text-[#191265] hover:scale-110 transition-transform" aria-label={`Project details for ${title}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="square" stroke-linejoin="round">
            <path d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </a>
      </div>
    </div>
    
    <p class="text-[#191265]/70 font-bold text-sm leading-tight uppercase tracking-tight">
      {description}
    </p>

    <div class="pt-4 flex items-center gap-4">
      <div class="h-[2px] flex-1 bg-[#191265]/10 group-hover:bg-[#191265] transition-colors duration-500"></div>
      <span class="text-[10px] font-black text-[#191265]/40 group-hover:text-[#191265] transition-colors">VIEW_DETAILS</span>
    </div>
  </div>
</div>
