---
// Comentario en espanol mexicano: este componente o pagina arma una seccion del portafolio.
// Archivo: ProjectCard.astro
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  image: string;
  tags: string[];
  link: string;
  github?: string;
}

const { title, description, image, tags, link, github } = Astro.props;
---

<div class="group/project relative overflow-hidden rounded-2xl border border-[#191265]/8 bg-white shadow-lg transition-all duration-500 hover:-translate-y-3 hover:shadow-2xl">
  <!-- Image Container -->
  <div class="relative h-56 overflow-hidden bg-gradient-to-br from-[#191265]/5 to-[#7c3aed]/5">
    <img
      src={image}
      alt={title}
      class="h-full w-full object-cover grayscale transition-all duration-500 group-hover/project:grayscale-0 group-hover/project:scale-110"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-white/80 via-transparent to-transparent opacity-0 group-hover/project:opacity-100 transition-opacity duration-500"></div>
    
    <!-- Tags Overlay -->
    <div class="absolute top-4 left-4 right-4 flex flex-wrap gap-2">
      {tags.map(tag => (
        <span class="inline-block bg-[#191265]/80 backdrop-blur-sm text-white text-[9px] font-black uppercase px-2.5 py-1 tracking-wider rounded-full">
          {tag}
        </span>
      ))}
    </div>
  </div>

  <!-- Content -->
  <div class="p-6 md:p-8 space-y-5">
    <div class="flex justify-between items-start gap-4">
      <h3 class="text-2xl md:text-3xl font-black uppercase tracking-tight text-[#191265] leading-tight">
        {title}
      </h3>
      <div class="flex items-center gap-2 shrink-0">
        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`GitHub repository for ${title}`}
            class="flex h-10 w-10 items-center justify-center rounded-lg border border-[#191265]/10 bg-[#191265]/5 text-[#191265] transition-all duration-300 hover:border-[#191265]/40 hover:bg-[#191265] hover:text-white"
          >
            <Icon name="lucide:github" class="h-4 w-4" aria-hidden="true" />
          </a>
        )}
        <a
          href={link}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View project ${title}`}
          class="flex h-10 w-10 items-center justify-center rounded-lg border border-[#7c3aed]/20 bg-[#7c3aed]/10 text-[#7c3aed] transition-all duration-300 hover:border-[#7c3aed] hover:bg-[#7c3aed] hover:text-white"
        >
          <Icon name="lucide:external-link" class="h-4 w-4" aria-hidden="true" />
        </a>
      </div>
    </div>
    
    <p class="text-[15px] md:text-[16px] text-[#191265]/70 leading-relaxed font-medium">
      {description}
    </p>

    <div class="pt-4 border-t border-[#191265]/8 flex items-center justify-between">
      <div class="h-[2px] flex-1 bg-gradient-to-r from-[#191265]/20 to-transparent group-hover/project:from-[#7c3aed]/40 transition-all duration-500"></div>
      <span class="text-[9px] font-mono text-[#191265]/40 group-hover/project:text-[#7c3aed] transition-colors ml-4 whitespace-nowrap uppercase tracking-wider">Explore →</span>
    </div>
  </div>
</div>
