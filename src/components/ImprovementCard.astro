---
// Comentario en español mexicano: este componente muestra una tarjeta de mejora individual.
// Archivo: ImprovementCard.astro
import { Icon } from 'astro-icon/components';

interface Props {
  id: number;
  title: string;
  description: string;
  status: string;
  progress: number;
  technologies: string[];
  startDate: string;
  estimatedDate: string;
  icon: string;
}

const { id, title, description, status, progress, technologies, startDate, estimatedDate, icon } = Astro.props;

const statusColor = status === 'In Progress' ? '#4ECDC4' : '#7B68EE';
const statusBg = status === 'In Progress' ? 'bg-[#4ECDC4]/10' : 'bg-[#7B68EE]/10';
---

<div class="group relative border-2 border-[#191265]/20 bg-[#F9F8F3] p-8 md:p-10 overflow-hidden hover:border-[#191265]/40 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-[12px_12px_0px_0px_#1912651f]">
  <!-- Gradient accent bar at top -->
  <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-[#191265] via-[#1d4ed8] to-[#191265]"></div>
  
  <!-- Status indicator -->
  <div class="absolute top-6 right-6">
    <div class={`${statusBg} px-3 py-1.5 rounded-full border border-current`} style={{ color: statusColor }}>
      <span class="text-[10px] font-black uppercase tracking-[0.2em]">{status}</span>
    </div>
  </div>

  <!-- Icon and Title -->
  <div class="flex items-start gap-4 mb-6">
    <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-[#191265]/8">
      <Icon name={icon} class="w-6 h-6 text-[#191265]" />
    </div>
    <div class="flex-1 pt-1">
      <h3 class="text-2xl font-black text-[#191265] uppercase tracking-tight leading-tight">
        {title}
      </h3>
      <div class="mt-2 w-12 h-1 bg-gradient-to-r from-[#1d4ed8] to-transparent rounded-full"></div>
    </div>
  </div>

  <!-- Description -->
  <p class="text-sm md:text-base text-[#191265]/75 font-semibold leading-relaxed mb-6">
    {description}
  </p>

  <!-- Progress Bar -->
  <div class="mb-6">
    <div class="flex items-center justify-between gap-2 mb-2">
      <span class="text-[10px] font-black uppercase tracking-[0.2em] text-[#191265]/60">Progress</span>
      <span class="text-[10px] font-bold text-[#191265]/70">{progress}%</span>
    </div>
    <div class="h-2 bg-[#191265]/8 rounded-full overflow-hidden">
      <div 
        class="h-full bg-gradient-to-r from-[#191265] to-[#1d4ed8] rounded-full transition-all duration-500 group-hover:shadow-[0_0_12px_rgba(25,18,101,0.3)]"
        style={{ width: `${progress}%` }}
      ></div>
    </div>
  </div>

  <!-- Timeline Info -->
  <div class="grid grid-cols-2 gap-4 mb-6 pb-6 border-b border-[#191265]/10">
    <div>
      <span class="text-[9px] font-black uppercase tracking-[0.2em] text-[#191265]/50">Start Date</span>
      <p class="text-sm font-bold text-[#191265] mt-1">{startDate}</p>
    </div>
    <div class="text-right">
      <span class="text-[9px] font-black uppercase tracking-[0.2em] text-[#191265]/50">Estimated</span>
      <p class="text-sm font-bold text-[#191265] mt-1">{estimatedDate}</p>
    </div>
  </div>

  <!-- Technologies -->
  <div>
    <span class="text-[9px] font-black uppercase tracking-[0.2em] text-[#191265]/50 mb-3 block">Stack</span>
    <div class="flex flex-wrap gap-2">
      {technologies.map((tech) => (
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-[#191265]/8 border border-[#191265]/15 rounded-lg group-hover:border-[#191265]/30 transition-colors duration-300">
          <span class="text-xs font-bold uppercase tracking-widest text-[#191265]/70 group-hover:text-[#191265]">
            {tech}
          </span>
        </div>
      ))}
    </div>
  </div>

  <!-- Decorative element -->
  <div class="absolute -bottom-8 -right-8 w-24 h-24 rounded-full bg-[#191265]/3 group-hover:bg-[#191265]/5 transition-colors duration-300"></div>
</div>
