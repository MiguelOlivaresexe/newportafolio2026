---
// Comentario en espanol mexicano: este componente o pagina arma una seccion del portafolio.
// Archivo: Navbar.astro
/**
 * Navbar.astro
 * Componente de navegacion con efecto Glassmorphism y cambio de idioma.
 */
import { Icon } from 'astro-icon/components';
import { translations } from '../data/translations';

const links = [
  { href: '#profile', labelKey: 'profile' },
  { href: '#skills', labelKey: 'skills' },
  { href: '#education', labelKey: 'education' },
  { href: '#certifications', labelKey: 'certifications' },
  { href: '#work-experience', labelKey: 'workExperience' },
  { href: '#contact', labelKey: 'contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-[100] px-4 md:px-8 py-4 transition-all duration-500 ease-in-out">
  <div id="navbar-shell" class="mx-auto flex max-w-6xl items-center gap-4 rounded-[1.1rem] border border-[#1f2558]/12 bg-[rgba(248,247,242,0.92)] px-4 py-3 shadow-[0_14px_32px_-24px_rgba(20,26,58,0.4)] backdrop-blur-md transition-all duration-500">
    <a href="/" class="group flex items-center gap-3 shrink-0">
      <div class="grid h-10 w-10 place-items-center rounded-[0.85rem] bg-[#1f2558] text-[#f3f0e6] shadow-[0_8px_20px_-14px_rgba(31,37,88,0.65)] transition-transform duration-300 group-hover:-translate-y-0.5">
        <span class="text-sm font-black tracking-[0.08em]">M</span>
      </div>
      <div class="hidden sm:block leading-none">
        <p class="text-[0.95rem] font-semibold tracking-[0.16em] uppercase text-[#1f2558]">MAOH</p>
        <p class="mt-1 text-[0.58rem] font-semibold uppercase tracking-[0.28em] text-[#1f2558]/55">Portfolio</p>
      </div>
    </a>

    <div class="hidden lg:flex flex-1 items-center justify-center">
      <div class="flex items-center gap-1 rounded-[999px] border border-[#1f2558]/10 bg-white/80 px-1.5 py-1">
        {links.map((link) => (
          <a
            href={link.href}
            data-translate={link.labelKey}
            class="nav-link group relative rounded-[999px] px-3.5 py-1.5 text-[10px] font-semibold uppercase tracking-[0.14em] text-[#1f2558]/70 transition-colors duration-250 hover:bg-[#1f2558]/6 hover:text-[#1f2558]"
          >
            {translations.en[link.labelKey]}
            <span class="nav-underline absolute inset-x-3 bottom-[0.28rem] h-px bg-[#1f2558]/45 scale-x-0 origin-left transition-transform duration-250 group-hover:scale-x-100"></span>
          </a>
        ))}
      </div>
    </div>

    <div class="flex items-center gap-2 shrink-0">
      <a href="#contact" data-translate="contact" class="hidden md:inline-flex items-center rounded-full border border-[#1f2558]/12 bg-[#1f2558] px-4 py-2 text-[10px] font-semibold uppercase tracking-[0.18em] text-[#f3f0e6] transition-colors duration-250 hover:bg-[#2a3373]">
        {translations.en.contact}
      </a>

      <a href="https://github.com/tu-usuario" target="_blank" rel="noopener noreferrer" class="group flex h-10 w-10 items-center justify-center rounded-full border border-[#1f2558]/10 bg-white/90 text-[#1f2558] transition-all duration-250 hover:bg-white" aria-label="GitHub profile">
        <Icon name="lucide:github" class="h-[15px] w-[15px] transition-transform duration-250 group-hover:scale-110" aria-hidden="true" />
      </a>

      <a href="https://www.linkedin.com/in/tu-usuario" target="_blank" rel="noopener noreferrer" class="group flex h-10 w-10 items-center justify-center rounded-full border border-[#1f2558]/10 bg-white/90 text-[#1f2558] transition-all duration-250 hover:bg-white" aria-label="LinkedIn profile">
        <Icon name="lucide:linkedin" class="h-[15px] w-[15px] transition-transform duration-250 group-hover:scale-110" aria-hidden="true" />
      </a>

      <button id="translator-toggle" class="group flex h-10 w-10 items-center justify-center rounded-full border border-[#1f2558]/10 bg-white/90 text-[#1f2558] transition-all duration-250 hover:bg-white" aria-label="Toggle language" title="Change language">
        <Icon name="lucide:languages" class="h-[15px] w-[15px] transition-transform duration-250 group-hover:scale-110" aria-hidden="true" />
      </button>

      <button id="mobile-menu-toggle" class="lg:hidden flex h-10 w-10 items-center justify-center rounded-full border border-[#1f2558]/12 bg-[#1f2558] text-[#f3f0e6] transition-colors duration-250 hover:bg-[#2a3373]" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu-overlay" class="fixed inset-0 z-[110] bg-[#10153a]/40 backdrop-blur-[3px] opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"></div>

  <div id="mobile-menu" class="fixed top-[5.8rem] left-4 right-4 z-[120] overflow-hidden rounded-[1rem] border border-[#1f2558]/12 bg-[rgba(248,247,242,0.98)] p-4 shadow-[0_24px_44px_-30px_rgba(20,26,58,0.45)] opacity-0 -translate-y-3 pointer-events-none transition-all duration-300 lg:hidden">
    <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#1f2558]/35 to-transparent"></div>
    <div class="relative flex items-center justify-between border-b border-[#1f2558]/12 pb-3">
      <div>
        <p class="text-[10px] font-semibold uppercase tracking-[0.24em] text-[#1f2558]/72">Navigation</p>
        <p class="mt-1 text-[9px] font-medium uppercase tracking-[0.22em] text-[#1f2558]/46">Quick access</p>
      </div>
      <button id="mobile-menu-close" class="p-2 text-[#1f2558] hover:text-[#1f2558]/80 transition-colors" aria-label="Close menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>

    <div class="mt-3 flex flex-col gap-2">
      {links.map((link) => (
        <a
          href={link.href}
          data-translate={link.labelKey}
          class="mobile-link rounded-[0.9rem] border border-[#1f2558]/12 bg-white/88 px-4 py-3 text-base font-medium tracking-[0.02em] text-[#1f2558] hover:border-[#1f2558]/28 hover:bg-white transition-all duration-250 opacity-0 translate-y-4"
        >
          {translations.en[link.labelKey]}
        </a>
      ))}
    </div>

    <a href="#contact" data-translate="contact" class="mt-4 inline-flex w-full items-center justify-center rounded-[0.9rem] border border-[#1f2558]/12 bg-[#1f2558] px-4 py-3 text-xs font-semibold uppercase tracking-[0.18em] text-[#f3f0e6] transition-colors duration-250 hover:bg-[#2a3373]">
      {translations.en.contact}
    </a>
  </div>
</nav>

<script is:inline>
  (function () {
    const navbar = document.getElementById('navbar');
    const navbarShell = document.getElementById('navbar-shell');
    const desktopLinks = document.querySelectorAll('.nav-link');
    const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenuClose = document.getElementById('mobile-menu-close');
    const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    const translatorToggle = document.getElementById('translator-toggle');

    let currentLanguage = localStorage.getItem('language') || 'en';

    const updateTranslatorLabel = () => {
      if (!translatorToggle) return;
      const nextLanguage = currentLanguage === 'en' ? 'Spanish' : 'English';
      translatorToggle.setAttribute('title', `Switch to ${nextLanguage}`);
      translatorToggle.setAttribute('aria-label', `Switch to ${nextLanguage}`);
    };

    updateTranslatorLabel();

    if (navbar) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          navbar.classList.add('py-3');
          navbarShell?.classList.add('border-[#1f2558]/24', 'shadow-[0_22px_36px_-30px_rgba(20,26,58,0.45)]');
        } else {
          navbar.classList.remove('py-3');
          navbarShell?.classList.remove('border-[#1f2558]/24', 'shadow-[0_22px_36px_-30px_rgba(20,26,58,0.45)]');
        }
      });
    }

    const sectionIds = Array.from(desktopLinks)
      .map((link) => link.getAttribute('href') || '')
      .filter((href) => href.startsWith('#'));

    const setActiveLink = (id) => {
      desktopLinks.forEach((link) => {
        const isActive = link.getAttribute('href') === id;
        link.classList.toggle('bg-[#1f2558]/12', isActive);
        link.classList.toggle('text-[#1f2558]', isActive);
        link.querySelector('.nav-underline')?.classList.toggle('scale-x-100', isActive);
      });
    };

    const observedSections = sectionIds
      .map((id) => document.querySelector(id))
      .filter(Boolean);

    if (observedSections.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
          if (visible[0]) {
            setActiveLink(`#${visible[0].target.id}`);
          }
        },
        { rootMargin: '-35% 0px -55% 0px', threshold: [0.2, 0.4, 0.6] }
      );

      observedSections.forEach((section) => observer.observe(section));
    }

    if (translatorToggle) {
      translatorToggle.addEventListener('click', () => {
        currentLanguage = currentLanguage === 'en' ? 'es' : 'en';
        localStorage.setItem('language', currentLanguage);
        window.dispatchEvent(new CustomEvent('language-change', { detail: { lang: currentLanguage } }));
        updateTranslatorLabel();
      });
    }

    const openMobileMenu = () => {
      if (!mobileMenu || !mobileMenuOverlay) return;
      mobileMenu.classList.remove('opacity-0', '-translate-y-3', 'pointer-events-none');
      mobileMenu.classList.add('opacity-100', 'translate-y-0');
      mobileMenuOverlay.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenuOverlay.classList.add('opacity-100');
      mobileMenuToggle?.setAttribute('aria-expanded', 'true');
      document.body.classList.add('overflow-hidden');

      mobileLinks.forEach((link, index) => {
        setTimeout(() => {
          link.classList.remove('opacity-0', 'translate-y-4');
          link.classList.add('opacity-100', 'translate-y-0');
        }, index * 70);
      });
    };

    const closeMobileMenu = () => {
      if (!mobileMenu || !mobileMenuOverlay) return;
      mobileMenu.classList.add('opacity-0', '-translate-y-3', 'pointer-events-none');
      mobileMenu.classList.remove('opacity-100', 'translate-y-0');
      mobileMenuOverlay.classList.add('opacity-0', 'pointer-events-none');
      mobileMenuOverlay.classList.remove('opacity-100');
      mobileMenuToggle?.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('overflow-hidden');

      mobileLinks.forEach((link) => {
        link.classList.add('opacity-0', 'translate-y-4');
        link.classList.remove('opacity-100', 'translate-y-0');
      });
    };

    if (mobileMenuToggle && mobileMenu) {
      mobileMenuToggle.addEventListener('click', openMobileMenu);
    }

    if (mobileMenuClose) {
      mobileMenuClose.addEventListener('click', closeMobileMenu);
    }

    if (mobileMenuOverlay) {
      mobileMenuOverlay.addEventListener('click', closeMobileMenu);
    }

    mobileLinks.forEach((link) => {
      link.addEventListener('click', () => {
        closeMobileMenu();
      });
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && mobileMenu && !mobileMenu.classList.contains('pointer-events-none')) {
        closeMobileMenu();
      }
    });
  })();
</script>
