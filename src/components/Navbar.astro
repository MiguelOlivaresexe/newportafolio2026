---
// Comentario en espanol mexicano: este componente o pagina arma una seccion del portafolio.
// Archivo: Navbar.astro
/**
 * Navbar.astro
 * Componente de navegacion con efecto Glassmorphism y cambio de idioma.
 */
import { Icon } from 'astro-icon/components';
import { translations } from '../data/translations';

const links = [
  { href: '#profile', labelKey: 'profile' },
  { href: '#skills', labelKey: 'skills' },
  { href: '#education', labelKey: 'education' },
  { href: '#certifications', labelKey: 'certifications' },
  { href: '#work-experience', labelKey: 'workExperience' },
  { href: '#projects', labelKey: 'projects' },
  { href: '#contact', labelKey: 'contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-[100] px-4 md:px-8 py-4 md:py-5 transition-all duration-500 ease-in-out">
  <div id="navbar-shell" class="mx-auto flex max-w-6xl items-center justify-between rounded-2xl border border-[#191265]/8 bg-[rgba(240,238,233,0.92)] px-6 md:px-8 py-4 shadow-[0_8px_24px_-16px_rgba(25,18,101,0.12)] backdrop-blur-md transition-all duration-500">
    
    <!-- Desktop Navigation -->
    <div class="hidden lg:flex items-center gap-1">
      {links.map((link) => (
        <a
          href={link.href}
          data-translate={link.labelKey}
          class="nav-link px-4 py-2 text-xs font-semibold uppercase tracking-[0.15em] text-[#191265]/60 transition-all duration-300 hover:text-[#7c3aed] relative group"
        >
          {translations.en[link.labelKey]}
          <span class="absolute bottom-0 left-4 right-4 h-[2px] bg-[#7c3aed] scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></span>
        </a>
      ))}
    </div>

    <!-- Right Actions -->
    <div class="flex items-center gap-3 shrink-0">
      <a href="https://github.com/MiguelOlivaresexe" target="_blank" rel="noopener noreferrer" class="group hidden sm:flex h-9 w-9 items-center justify-center rounded-lg border border-[#191265]/8 bg-white/60 text-[#191265] transition-all duration-300 hover:border-[#7c3aed]/30 hover:bg-[#7c3aed]/8" aria-label="GitHub profile">
        <Icon name="lucide:github" class="h-4 w-4 transition-transform duration-300 group-hover:scale-110" aria-hidden="true" />
      </a>

      <a href="https://www.linkedin.com/in/miguel-angel-olivares" target="_blank" rel="noopener noreferrer" class="group hidden sm:flex h-9 w-9 items-center justify-center rounded-lg border border-[#191265]/8 bg-white/60 text-[#191265] transition-all duration-300 hover:border-[#7c3aed]/30 hover:bg-[#7c3aed]/8" aria-label="LinkedIn profile">
        <Icon name="lucide:linkedin" class="h-4 w-4 transition-transform duration-300 group-hover:scale-110" aria-hidden="true" />
      </a>

      <button id="translator-toggle" class="group flex h-9 w-9 items-center justify-center rounded-lg border border-[#191265]/8 bg-white/60 text-[#191265] transition-all duration-300 hover:border-[#7c3aed]/30 hover:bg-[#7c3aed]/8" aria-label="Toggle language" title="Change language">
        <Icon name="lucide:languages" class="h-4 w-4 transition-transform duration-300 group-hover:scale-110" aria-hidden="true" />
      </button>

      <a href="#contact" class="hidden md:inline-flex items-center rounded-lg border border-[#191265]/10 bg-[#191265] px-5 py-2 text-[10px] font-bold uppercase tracking-[0.2em] text-white transition-all duration-300 hover:border-[#7c3aed] hover:shadow-[0_12px_24px_-8px_rgba(124,58,237,0.2)]">
        Contact
      </a>

      <button id="mobile-menu-toggle" class="lg:hidden flex h-9 w-9 items-center justify-center rounded-lg border border-[#191265]/8 bg-white/60 text-[#191265] transition-colors duration-300 hover:bg-white" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu-overlay" class="fixed inset-0 z-[110] bg-[#191265]/20 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"></div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="fixed top-20 left-4 right-4 z-[120] overflow-hidden rounded-2xl border border-[#191265]/8 bg-[rgba(240,238,233,0.95)] p-5 shadow-[0_16px_32px_-12px_rgba(25,18,101,0.2)] opacity-0 -translate-y-3 pointer-events-none transition-all duration-300 lg:hidden backdrop-blur-md">
    <div class="relative flex items-center justify-between border-b border-[#191265]/8 pb-4">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[#191265]/70">Navigation</p>
      <button id="mobile-menu-close" class="p-1 -mr-1 text-[#191265] hover:text-[#7c3aed] transition-colors" aria-label="Close menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>

    <div class="mt-4 flex flex-col gap-2">
      {links.map((link) => (
        <a
          href={link.href}
          data-translate={link.labelKey}
          class="mobile-link rounded-lg border border-[#191265]/8 bg-white/60 px-4 py-3 text-sm font-semibold text-[#191265] transition-all duration-300 hover:border-[#7c3aed]/30 hover:bg-[#7c3aed]/8 hover:text-[#7c3aed] opacity-0 translate-y-2"
        >
          {translations.en[link.labelKey]}
        </a>
      ))}
    </div>

    <a href="#contact" class="mt-4 flex w-full items-center justify-center rounded-lg border border-[#191265]/10 bg-[#191265] px-4 py-3 text-xs font-bold uppercase tracking-[0.2em] text-white transition-all duration-300 hover:shadow-[0_12px_24px_-8px_rgba(124,58,237,0.2)]">
      Contact
    </a>
  </div>
</nav>

<script is:inline>
  (function () {
    const navbar = document.getElementById('navbar');
    const navbarShell = document.getElementById('navbar-shell');
    const desktopLinks = document.querySelectorAll('.nav-link');
    const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenuClose = document.getElementById('mobile-menu-close');
    const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    const translatorToggle = document.getElementById('translator-toggle');

    let currentLanguage = localStorage.getItem('language') || 'en';

    const updateTranslatorLabel = () => {
      if (!translatorToggle) return;
      const nextLanguage = currentLanguage === 'en' ? 'Spanish' : 'English';
      translatorToggle.setAttribute('title', `Switch to ${nextLanguage}`);
      translatorToggle.setAttribute('aria-label', `Switch to ${nextLanguage}`);
    };

    updateTranslatorLabel();

    if (navbar) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 36) {
          navbar.classList.remove('py-4', 'md:py-5');
          navbar.classList.add('py-3');
          navbarShell?.classList.add('border-[#191265]/12', 'bg-[rgba(240,238,233,0.95)]', 'shadow-[0_16px_32px_-12px_rgba(25,18,101,0.15)]');
        } else {
          navbar.classList.remove('py-3');
          navbar.classList.add('py-4', 'md:py-5');
          navbarShell?.classList.remove('border-[#191265]/12', 'bg-[rgba(240,238,233,0.95)]', 'shadow-[0_16px_32px_-12px_rgba(25,18,101,0.15)]');
        }
      });
    }

    const sectionIds = Array.from(desktopLinks)
      .map((link) => link.getAttribute('href') || '')
      .filter((href) => href.startsWith('#'));

    const setActiveLink = (id) => {
      desktopLinks.forEach((link) => {
        const isActive = link.getAttribute('href') === id;
        link.classList.toggle('text-[#7c3aed]', isActive);
        link.classList.toggle('text-[#191265]/60', !isActive);
      });
    };

    const observedSections = sectionIds
      .map((id) => document.querySelector(id))
      .filter(Boolean);

    if (observedSections.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
          if (visible[0]) {
            setActiveLink(`#${visible[0].target.id}`);
          }
        },
        { rootMargin: '-35% 0px -55% 0px', threshold: [0.2, 0.4, 0.6] }
      );

      observedSections.forEach((section) => observer.observe(section));
    }

    if (translatorToggle) {
      translatorToggle.addEventListener('click', () => {
        currentLanguage = currentLanguage === 'en' ? 'es' : 'en';
        localStorage.setItem('language', currentLanguage);
        window.dispatchEvent(new CustomEvent('language-change', { detail: { lang: currentLanguage } }));
        updateTranslatorLabel();
      });
    }

    const openMobileMenu = () => {
      if (!mobileMenu || !mobileMenuOverlay) return;
      mobileMenu.classList.remove('opacity-0', '-translate-y-3', 'pointer-events-none');
      mobileMenu.classList.add('opacity-100', 'translate-y-0');
      mobileMenuOverlay.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenuOverlay.classList.add('opacity-100');
      mobileMenuToggle?.setAttribute('aria-expanded', 'true');
      document.body.classList.add('overflow-hidden');

      mobileLinks.forEach((link, index) => {
        setTimeout(() => {
          link.classList.remove('opacity-0', 'translate-y-2');
          link.classList.add('opacity-100', 'translate-y-0');
        }, index * 70);
      });
    };

    const closeMobileMenu = () => {
      if (!mobileMenu || !mobileMenuOverlay) return;
      mobileMenu.classList.add('opacity-0', '-translate-y-3', 'pointer-events-none');
      mobileMenu.classList.remove('opacity-100', 'translate-y-0');
      mobileMenuOverlay.classList.add('opacity-0', 'pointer-events-none');
      mobileMenuOverlay.classList.remove('opacity-100');
      mobileMenuToggle?.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('overflow-hidden');

      mobileLinks.forEach((link) => {
        link.classList.add('opacity-0', 'translate-y-2');
        link.classList.remove('opacity-100', 'translate-y-0');
      });
    };

    if (mobileMenuToggle && mobileMenu) {
      mobileMenuToggle.addEventListener('click', openMobileMenu);
    }

    if (mobileMenuClose) {
      mobileMenuClose.addEventListener('click', closeMobileMenu);
    }

    if (mobileMenuOverlay) {
      mobileMenuOverlay.addEventListener('click', closeMobileMenu);
    }

    mobileLinks.forEach((link) => {
      link.addEventListener('click', () => {
        closeMobileMenu();
      });
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && mobileMenu && !mobileMenu.classList.contains('pointer-events-none')) {
        closeMobileMenu();
      }
    });
  })();
</script>
