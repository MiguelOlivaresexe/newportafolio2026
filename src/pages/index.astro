				const revealElements = document.querySelectorAll('.profile-reveal');
				if (revealElements.length > 0 && 'IntersectionObserver' in window) {
					const observer = new IntersectionObserver((entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								observer.unobserve(entry.target);
							}
						});
					}, { threshold: 0.2 });

					revealElements.forEach((el) => observer.observe(el));
				}
			});

		// Contact Modal Logic
		const openModalBtn = document.getElementById('open-contact-modal');
		const closeModalBtn = document.getElementById('close-contact-modal');
		const contactModal = document.getElementById('contact-modal');
		const modalContent = document.getElementById('modal-content');

		openModalBtn.addEventListener('click', () => {
			contactModal.classList.remove('opacity-0', 'pointer-events-none');
			modalContent.classList.remove('scale-95');
		});

		const closeModal = () => {
			modalContent.classList.add('scale-95');
			contactModal.classList.add('opacity-0');
			setTimeout(() => {
				contactModal.classList.add('pointer-events-none');
			}, 300);
		};

		closeModalBtn.addEventListener('click', closeModal);
		contactModal.addEventListener('click', (e) => {
			if (e.target === contactModal) {
				closeModal();
			}
		});
	</script>

<style>
	/* Custom animations for the hero text reveal */
	.hero-subtitle {
		animation: revealUp 0.8s cubic-bezier(0.2, 0.6, 0.2, 1) forwards;
		animation-delay: 0.2s;
	}
	
	.hero-title {
		animation: revealUp 1s cubic-bezier(0.2, 0.6, 0.2, 1) forwards;
		animation-delay: 0.4s;
	}

	.hero-description {
		animation: revealUp 1s cubic-bezier(0.2, 0.6, 0.2, 1) forwards;
		animation-delay: 0.6s;
	}

	.hero-cta {
		animation: fadeIn 1.2s ease-out forwards;
		animation-delay: 0.8s;
	}

	@keyframes revealUp {
		0% {
			transform: translateY(40px);
			opacity: 0;
		}
		100% {
			transform: translateY(0);
			opacity: 1;
		}
	}

	@keyframes fadeIn {
		0% {
			opacity: 0;
		}
		100% {
			opacity: 1;
		}
	}
</style>
