---
// Comentario en espanol mexicano: este componente o pagina arma una seccion del portafolio.
// Archivo: certificaciones.astro
/**
 * certificaciones.astro
 * Page to display all certifications.
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { certifications } from '../data/certifications';
import CertificationCard from '../components/CertificationCard.astro';
---

<Layout title="MAOH | Certifications">
	<main class="bg-pale-gray dark:bg-dark-background pt-28 md:pt-32">
		<Navbar />
		<section id="certifications" class="relative px-6 py-40 bg-[#191265] overflow-hidden border-t border-[#F0EEE9]/10">
			<!-- Minimal background texture -->
			<div class="absolute inset-0 pointer-events-none select-none">
				<div class="absolute inset-0 bg-[linear-gradient(to_right,#F0EEE904_1px,transparent_1px),linear-gradient(to_bottom,#F0EEE904_1px,transparent_1px)] bg-[size:5rem_5rem]"></div>
			</div>

			<div class="max-w-7xl mx-auto relative z-10">
				<!-- Header -->
				<div class="mb-8 flex items-end justify-between gap-6 border-b border-[#F0EEE9]/8 pb-8">
					<div>
						<p class="text-[10px] font-black uppercase tracking-[0.45em] text-[#F0EEE9]/40">Knowledge Matrix</p>
					</div>
					<div class="flex gap-8 text-right">
						<div>
							<p class="text-[10px] font-black uppercase tracking-[0.2em] text-[#F0EEE9]/40">Total</p>
							<p class="mt-2 text-3xl font-black text-[#F0EEE9]">{certifications.length}</p>
						</div>
						<div class="border-l border-[#F0EEE9]/10 pl-8">
							<p class="text-[10px] font-black uppercase tracking-[0.2em] text-[#F0EEE9]/40">Focus</p>
							<p class="mt-2 text-sm font-semibold text-[#F0EEE9]">Development<br/>Security</p>
						</div>
					</div>
				</div>

				<!-- Category pillars -->
				<div class="mb-20 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
					<div class="group border border-[#F0EEE9]/12 bg-[#F0EEE9]/[0.02] p-6 hover:bg-[#7B68EE]/8 transition-colors duration-300">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#F0EEE9]/40 mb-2">Development</p>
								<p class="text-2xl font-black text-[#F0EEE9]">3</p>
								<p class="text-xs text-[#F0EEE9]/60 mt-3 leading-snug">Web, JavaScript,<br/>Responsive Design</p>
							</div>
							<div class="flex h-8 w-1 bg-gradient-to-b from-[#7B68EE] to-[#7B68EE]/40 group-hover:from-[#9F8FFF] transition-all duration-300"></div>
						</div>
					</div>

					<div class="group border border-[#F0EEE9]/12 bg-[#F0EEE9]/[0.02] p-6 hover:bg-[#FF6B6B]/8 transition-colors duration-300">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#F0EEE9]/40 mb-2">Security</p>
								<p class="text-2xl font-black text-[#F0EEE9]">1</p>
								<p class="text-xs text-[#F0EEE9]/60 mt-3 leading-snug">ISO/IEC 27001<br/>Lead Auditor</p>
							</div>
							<div class="flex h-8 w-1 bg-gradient-to-b from-[#FF6B6B] to-[#FF6B6B]/40 group-hover:from-[#FF8787] transition-all duration-300"></div>
						</div>
					</div>

					<div class="group border border-[#F0EEE9]/12 bg-[#F0EEE9]/[0.02] p-6 hover:bg-[#4ECDC4]/8 transition-colors duration-300 sm:col-span-2 lg:col-span-1">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#F0EEE9]/40 mb-2">Providers</p>
								<p class="text-2xl font-black text-[#F0EEE9]">3</p>
								<p class="text-xs text-[#F0EEE9]/60 mt-3 leading-snug">Academy, Campus,<br/>Standards</p>
							</div>
							<div class="flex h-8 w-1 bg-gradient-to-b from-[#4ECDC4] to-[#4ECDC4]/40 group-hover:from-[#6FE1D9] transition-all duration-300"></div>
						</div>
					</div>
				</div>

				<!-- Main title -->
				<div class="mb-20">
					<h3 class="text-6xl md:text-8xl leading-[0.8] tracking-[-0.04em] text-[#F0EEE9]">
						<span class="block font-black uppercase tracking-tight">Professional</span>
						<span class="block [font-family:'Outfit',sans-serif] font-bold italic lowercase tracking-widest text-[#F0EEE9]/92">credentials</span>
					</h3>
				</div>

				<!-- Certifications grid with category colors -->
				<div class="space-y-16">
					<!-- Development Section -->
					<div>
						<div class="mb-8 flex items-center gap-4 border-l-4 border-[#7B68EE] pl-6">
							<div className="h-2 w-2 rounded-full bg-[#7B68EE]"></div>
							<p class="text-sm font-black uppercase tracking-[0.3em] text-[#F0EEE9]/60">Development Certifications</p>
						</div>
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
							{certifications.filter((_, i) => i !== 3).map((certification, index) => (
								<div class="group relative overflow-hidden border-l-4 border-[#7B68EE] border-t border-r border-b border-[#F0EEE9]/12 bg-[#F0EEE9]/[0.02] p-6 md:p-8 text-[#F0EEE9] backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-l-[#9F8FFF] hover:border-t-[#F0EEE9]/20 hover:bg-[#7B68EE]/5">
									<div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#7B68EE]/30 to-transparent"></div>
									<div class="pointer-events-none absolute right-6 top-6 text-4xl font-black leading-none tracking-[-0.08em] text-[#7B68EE]/12 md:text-5xl">{String(index + 1).padStart(2, '0')}</div>

									<div class="relative z-10 flex h-full flex-col gap-6">
										<div class="flex items-center justify-between gap-3 border-b border-[#F0EEE9]/12 pb-4">
											<div class="inline-flex items-center gap-2 bg-[#7B68EE]/10 px-3 py-1.5">
												<span class="h-1.5 w-1.5 rounded-full bg-[#7B68EE]/80"></span>
												<span class="text-[10px] font-bold uppercase tracking-[0.2em] text-[#F0EEE9]/70">{certification.issuer}</span>
											</div>
											<span class="text-[10px] font-mono tracking-[0.2em] text-[#F0EEE9]/40">DEV-{String(index + 1).padStart(2, '0')}</span>
										</div>

										<div class="space-y-3">
											<p class="text-[10px] font-black uppercase tracking-[0.28em] text-[#F0EEE9]/45">Credential</p>
											<h4 class="max-w-xs text-xl font-black leading-tight tracking-tight text-[#F0EEE9] md:text-2xl">
												{certification.name}
											</h4>
										</div>

										<div class="mt-auto space-y-4">
											<div class="h-px w-12 bg-[#7B68EE]/40 transition-all duration-300 group-hover:w-20"></div>
											<div class="flex items-center justify-between gap-4">
												<span class="text-xs font-bold uppercase tracking-[0.16em] text-[#F0EEE9]/55">Issued {certification.date}</span>
												<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="round" class="text-[#7B68EE]/50 transition-all duration-300 group-hover:text-[#7B68EE]">
													<path d="M7 17L17 7M17 7H7M17 7V17"/>
												</svg>
											</div>
										</div>
									</div>
								</div>
							))}
						</div>
					</div>

					<!-- Security Section -->
					<div>
						<div class="mb-8 flex items-center gap-4 border-l-4 border-[#FF6B6B] pl-6">
							<div className="h-2 w-2 rounded-full bg-[#FF6B6B]"></div>
							<p class="text-sm font-black uppercase tracking-[0.3em] text-[#F0EEE9]/60">Security & Standards</p>
						</div>
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
							{certifications.filter((_, i) => i === 3).map((certification, index) => (
								<div class="group relative overflow-hidden border-l-4 border-[#FF6B6B] border-t border-r border-b border-[#F0EEE9]/12 bg-[#F0EEE9]/[0.02] p-6 md:p-8 text-[#F0EEE9] backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-l-[#FF8787] hover:border-t-[#F0EEE9]/20 hover:bg-[#FF6B6B]/5">
									<div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[#FF6B6B]/30 to-transparent"></div>
									<div class="pointer-events-none absolute right-6 top-6 text-4xl font-black leading-none tracking-[-0.08em] text-[#FF6B6B]/12 md:text-5xl">04</div>

									<div class="relative z-10 flex h-full flex-col gap-6">
										<div class="flex items-center justify-between gap-3 border-b border-[#F0EEE9]/12 pb-4">
											<div class="inline-flex items-center gap-2 bg-[#FF6B6B]/10 px-3 py-1.5">
												<span class="h-1.5 w-1.5 rounded-full bg-[#FF6B6B]/80"></span>
												<span class="text-[10px] font-bold uppercase tracking-[0.2em] text-[#F0EEE9]/70">{certification.issuer}</span>
											</div>
											<span class="text-[10px] font-mono tracking-[0.2em] text-[#F0EEE9]/40">SEC-04</span>
										</div>

										<div class="space-y-3">
											<p class="text-[10px] font-black uppercase tracking-[0.28em] text-[#F0EEE9]/45">Credential</p>
											<h4 class="max-w-xs text-xl font-black leading-tight tracking-tight text-[#F0EEE9] md:text-2xl">
												{certification.name}
											</h4>
										</div>

										<div class="mt-auto space-y-4">
											<div class="h-px w-12 bg-[#FF6B6B]/40 transition-all duration-300 group-hover:w-20"></div>
											<div class="flex items-center justify-between gap-4">
												<span class="text-xs font-bold uppercase tracking-[0.16em] text-[#F0EEE9]/55">Issued {certification.date}</span>
												<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="round" class="text-[#FF6B6B]/50 transition-all duration-300 group-hover:text-[#FF6B6B]">
													<path d="M7 17L17 7M17 7H7M17 7V17"/>
												</svg>
											</div>
										</div>
									</div>
								</div>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
