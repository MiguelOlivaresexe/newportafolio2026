---
// Comentario en espanol mexicano: este componente o pagina arma una seccion del portafolio.
// Archivo: [slug].astro
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';

export function getStaticPaths() {
  return [
    { params: { slug: 'able-platform' }, props: { title: "Able platform", category: "Product Design", image: "https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop" } },
    { params: { slug: 'moodys-analytics' }, props: { title: "Moody's Analytics", category: "Branding", image: "https://images.unsplash.com/photo-1633356122544-f134324a6cee?q=80&w=2670&auto=format&fit=crop" } },
    { params: { slug: 'linear-redesign' }, props: { title: "Linear Redesign", category: "UI/UX", image: "https://images.unsplash.com/photo-1558655146-d09347e92766?q=80&w=2564&auto=format&fit=crop" } },
    { params: { slug: 'spatial-audio' }, props: { title: "Spatial Audio", category: "Interaction", image: "https://images.unsplash.com/photo-1614850523296-d8c1af93d400?q=80&w=2670&auto=format&fit=crop" } },
  ];
}

const { slug } = Astro.params;
const { title, category, image } = Astro.props;
---

<Layout title={`${title} | Case Study`}>
  <Navbar />
  
  <main class="pt-28 md:pt-32 px-6 md:px-12">
    <div class="mb-16">
      <a href="/" class="inline-flex items-center gap-2 text-sm uppercase tracking-widest text-rich-blue/60 hover:text-rich-blue transition-colors mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Back to projects
      </a>
      <h1 class="text-6xl md:text-9xl font-bold uppercase tracking-tighter" transition:name={`title-${slug}`}>
        {title}
      </h1>
      <p class="text-xl md:text-2xl text-rich-blue/60 mt-4 uppercase tracking-widest" transition:name={`category-${slug}`}>
        {category}
      </p>
    </div>

    <div class="w-full aspect-video overflow-hidden bg-pale-gray mb-24" transition:name={`image-${slug}`}>
      <img 
        src={image} 
        alt={title} 
        class="w-full h-full object-cover"
      />
    </div>

    <div class="max-w-3xl mx-auto mb-32">
      <h2 class="text-3xl font-bold uppercase mb-8">The Challenge</h2>
      <p class="text-xl text-rich-blue/80 leading-relaxed mb-12">
        In 2026, the digital landscape demands more than just functionality. It requires emotional resonance and seamless integration between AI and human interaction. This project focuses on bridging that gap through a minimalist yet powerful interface.
      </p>
      
      <div class="grid grid-cols-2 gap-12 mb-12">
        <div>
          <h3 class="text-sm uppercase tracking-widest text-rich-blue/40 mb-2">Role</h3>
          <p class="text-lg">Lead Product Designer</p>
        </div>
        <div>
          <h3 class="text-sm uppercase tracking-widest text-rich-blue/40 mb-2">Duration</h3>
          <p class="text-lg">6 Months</p>
        </div>
      </div>

      <img 
        src="https://images.unsplash.com/photo-1558591710-4b4a1ae0f04d?q=80&w=2574&auto=format&fit=crop" 
        alt="Process" 
        class="w-full aspect-square object-cover mb-12"
      />

      <p class="text-xl text-rich-blue/80 leading-relaxed">
        The result is a platform that feels intuitive, responsive, and ready for the next decade of digital evolution.
      </p>
    </div>
  </main>
</Layout>
