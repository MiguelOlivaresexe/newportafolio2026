---
// Comentario en espanol mexicano: este componente o pagina arma una seccion del portafolio.
// Archivo: Layout.astro
/**
 * Layout.astro
 * Componente base que define la estructura HTML general, fuentes y configuración global.
 * Maneja la persistencia del tema (oscuro/claro) y elementos decorativos globales.
 */
import { ClientRouter } from 'astro:transitions';
import CustomCursor from '../components/CustomCursor.astro';
import { translations } from '../data/translations';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/lighthouse.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Fuentes de Google: Inter para cuerpo, Outfit para títulos y una tipografía creativa para el saludo -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@1,400;1,700&family=Cormorant+Garamond:ital,wght@1,500&display=swap" rel="stylesheet">
		
		<!-- Soporte para transiciones entre páginas de Astro -->
		<ClientRouter />

		<script is:inline>
			/**
			 * Inicialización del tema antes de que el contenido se renderice (FOUC fix).
			 * Prioridad: localStorage > Preferencia del sistema > light (default).
			 */
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
		
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		
			window.localStorage.setItem('theme', theme);
		</script>
	</head>
	<body class="bg-pale-gray dark:bg-dark-background text-rich-blue dark:text-dark-text antialiased selection:bg-rich-blue selection:text-pale-gray dark:selection:bg-pale-gray dark:selection:text-rich-blue relative">
		<!-- Cursor personalizado que sigue el movimiento del ratón -->
		<CustomCursor />
		
		<!-- Capa de ruido (grain texture) para un acabado visual más orgánico -->
		<div class="fixed inset-0 pointer-events-none z-[9999] opacity-[0.03] bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"></div>
		
		<!-- Punto de inserción para el contenido de cada página -->
		<slot />

		<script define:vars={{ translations }}>
      function applyTranslations(lang) {
        const translationSet = translations[lang];
        if (!translationSet) return;

        document.querySelectorAll('[data-translate]').forEach(element => {
          const key = element.getAttribute('data-translate');
					if (key === 'heroTitle') return;
          if (translationSet[key]) {
            if (translationSet[key].includes('\\n')) {
              element.innerHTML = translationSet[key].replace(/\\n/g, '<br>');
            } else {
              element.textContent = translationSet[key];
            }
          }
        });
      }

      // Apply initial translation on page load
      const initialLang = localStorage.getItem('language') || 'en';
      applyTranslations(initialLang);

      // Listen for language change events from Navbar
      window.addEventListener('language-change', (event) => {
        applyTranslations(event.detail.lang);
      });

      // Re-apply on Astro's page transition
      document.addEventListener('astro:after-swap', () => {
        const lang = localStorage.getItem('language') || 'en';
        applyTranslations(lang);
      });
    </script>
	</body>
</html>

<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
	html {
		font-family: 'Inter', system-ui, sans-serif;
		scroll-behavior: smooth;
	}
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Outfit', sans-serif;
	}
</style>
